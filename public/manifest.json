{
  "manifest_version": 3,
  "name": "Vault-Shield",
  "version": "1.0.0",
  "description": "Real-time password security assistant with smart suggestions.",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "placeholder.svg",
      "48": "placeholder.svg",
      "128": "placeholder.svg"
    }
  },
  "icons": {
    "16": "placeholder.svg",
    "48": "placeholder.svg",
    "128": "placeholder.svg"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/inject.tsx"],
      "css": ["src/globals.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/globals.css"],
      "matches": ["<all_urls>"]
    }
  ]
}